{
  "name": "medibook-backend",
  "version": "1.0.0",
  "description": "MediBook Backend — Fastify API, AI Voice Agent, Stripe Billing",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "npx prisma generate && npx prisma db push --accept-data-loss && node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "echo 'No build step required for ESM Node.js'",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:dev": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "db:seed": "node src/scripts/seed.js",
    "stripe:listen": "stripe listen --forward-to localhost:3001/billing/webhooks"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/static": "^7.0.0",
    "@fastify/websocket": "^8.3.0",
    "@prisma/client": "^5.14.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.0",
    "openai": "^4.47.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.14.0",
    "stripe": "^15.7.0",
    "twilio": "^5.3.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
