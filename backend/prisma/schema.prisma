// ─────────────────────────────────────────────────────────────────────────────
// prisma/schema.prisma
// MediBook — Full Database Schema
// PostgreSQL with Row-Level Security (RLS) via tenant_id on all tables.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS ──────────────────────────────────────────────────────────────────
model Tenant {
  id                   String   @id @default(uuid())
  slug                 String   @unique @db.VarChar(63)  // e.g. "lumiere-clinic"
  name                 String   @db.VarChar(255)
  plan                 Plan     @default(STARTER)
  stripeCustomerId     String?  @db.VarChar(255)
  stripeSubscriptionId String?  @db.VarChar(255)
  // clinicStatus: pending_payment | onboarding_required | onboarding_submitted | setup_in_progress | testing | live | paused
  clinicStatus         String   @default("live")
  settings             Json     @default("{}")           // timezone, address, brand colors, voice agent config
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  users             User[]
  staff             Staff[]
  clients           Client[]
  services          Service[]
  appointments      Appointment[]
  locations         Location[]
  callLogs          CallLog[]
  subscriptions     Subscription[]
  activityLogs      ActivityLog[]
  onboardingToken   OnboardingToken?
  consultationRule  ConsultationRule?
  blackoutDates     BlackoutDate[]
  bookingEngineLogs BookingEngineLog[]
  brandVoice        BrandVoice?

  @@map("tenants")
}

enum Plan {
  STARTER
  PRO
}

// ─── USERS (authentication) ───────────────────────────────────────────────────
model User {
  id              String    @id @default(uuid())
  tenantId        String
  email           String    @unique @db.VarChar(255)
  username        String    @unique @db.VarChar(63)
  passwordHash    String    @db.VarChar(255)
  fullName        String    @db.VarChar(255)
  title           String?   @db.VarChar(50)   // e.g. "Dr.", "Ms."
  phone           String?   @db.VarChar(30)
  avatarUrl       String?   @db.VarChar(500)
  isAvailable     Boolean   @default(true)
  role            UserRole  @default(OWNER)
  platformRole    String    @default("CLINIC")  // SUPERADMIN | CLINIC
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── PENDING REGISTRATIONS ────────────────────────────────────────────────────
// Holds signup state between form submission and email verification.
// Also used for admin-initiated Stripe-first clinic creation flow.
// status: "awaiting_email_verify" | "awaiting_payment" | "processed"
model PendingRegistration {
  id           String   @id @default(uuid())
  planKey      String   @db.VarChar(20)
  businessName String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(63)
  fullName     String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  username     String   @unique @db.VarChar(63)
  phone        String?  @db.VarChar(30)
  passwordHash String   @db.VarChar(255)
  verifyCode   String   @db.VarChar(6)
  verifyExpiry DateTime
  status       String   @default("awaiting_email_verify")  // awaiting_email_verify | awaiting_payment | processed
  createdAt    DateTime @default(now())

  @@map("pending_registrations")
}

// ─── LOCATIONS ────────────────────────────────────────────────────────────────
model Location {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String
  phone     String?
  timezone  String   @default("Europe/London")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff        Staff[]
  appointments Appointment[]

  @@index([tenantId])
  @@map("locations")
}

// ─── STAFF ────────────────────────────────────────────────────────────────────
model Staff {
  id          String    @id @default(uuid())
  tenantId    String
  locationId  String?
  email       String
  name        String
  title       String?   @db.VarChar(50)   // e.g. "Dr.", "Nurse"
  role        StaffRole @default(STAFF)
  color       String    @default("#60a5fa") // Calendar color
  avatarUrl   String?
  isAvailable Boolean   @default(true)    // currently accepting bookings today
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location     Location?     @relation(fields: [locationId], references: [id])
  availability Availability[]
  appointments Appointment[]
  services     StaffService[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("staff")
}

enum StaffRole {
  OWNER
  ADMIN
  STAFF
  RECEPTIONIST
}

// ─── STAFF AVAILABILITY ───────────────────────────────────────────────────────
model Availability {
  id        String @id @default(uuid())
  staffId   String
  dayOfWeek Int    // 0=Sun, 1=Mon, ..., 6=Sat
  startTime String // "09:00"
  endTime   String // "18:00"

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@map("availability")
}

// ─── SERVICES ─────────────────────────────────────────────────────────────────
model Service {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  description   String?
  durationMins  Int      // e.g. 60
  priceCents    Int      // e.g. 18000 = £180.00
  depositCents  Int      @default(0)
  color                String   @default("#d4a84b")
  isActive             Boolean  @default(true)
  consultationRequired Boolean  @default(false)
  category             String?  // e.g. "Facial Treatments"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  staffLinks   StaffService[]

  @@index([tenantId])
  @@map("services")
}

// ─── STAFF <> SERVICE (M2M) ───────────────────────────────────────────────────
model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

// ─── CLIENTS ──────────────────────────────────────────────────────────────────
model Client {
  id              String    @id @default(uuid())
  tenantId        String
  fullName        String    @db.VarChar(255)
  email           String?   @db.VarChar(255)
  phone           String?   @db.VarChar(30)
  dateOfBirth     DateTime? @db.Date
  // NOTE: medicalNotes encrypted at application layer before storage
  medicalNotes    String?   @db.Text
  gdprConsentAt   DateTime?
  stripeCustomerId String?  @db.VarChar(255)
  noShowCount     Int       @default(0)
  noShowRisk      Float     @default(0)  // 0.0–1.0, updated by ML job
  tags            String[]  @default([])
  source          String?   // "online_booking" | "walk_in" | "voice_agent" | "import"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  payments     Payment[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@map("clients")
}

// ─── APPOINTMENTS ─────────────────────────────────────────────────────────────
model Appointment {
  id                  String            @id @default(uuid())
  tenantId            String
  clientId            String
  staffId             String
  serviceId           String
  locationId          String?
  startsAt            DateTime
  endsAt              DateTime
  status              AppointmentStatus @default(CONFIRMED)
  source              String?           // "online" | "voice_agent" | "dashboard" | "api"
  notes               String?           @db.Text
  internalNotes       String?           @db.Text
  depositRequired     Boolean           @default(false)
  cancelledAt         DateTime?
  cancellationReason  String?
  completedAt         DateTime?
  reminderSentAt      DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  service  Service   @relation(fields: [serviceId], references: [id])
  location          Location?          @relation(fields: [locationId], references: [id])
  payments          Payment[]
  bookingEngineLogs BookingEngineLog[]

  @@index([tenantId, startsAt])
  @@index([tenantId, clientId])
  @@index([tenantId, staffId])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────────
model Payment {
  id                String        @id @default(uuid())
  tenantId          String
  clientId          String
  appointmentId     String?
  amountCents       Int
  currency          String        @default("gbp")
  type              PaymentType
  status            PaymentStatus @default(PENDING)
  stripePaymentId   String?       @unique @db.VarChar(255)
  stripeInvoiceId   String?       @db.VarChar(255)
  refundedAmountCents Int         @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  client      Client       @relation(fields: [clientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([clientId])
  @@map("payments")
}

enum PaymentType {
  DEPOSIT
  FULL_PAYMENT
  REFUND
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─── SUBSCRIPTIONS ────────────────────────────────────────────────────────────
model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// ─── CALL LOGS (AI Voice Agent) ───────────────────────────────────────────────
model CallLog {
  id            String   @id @default(uuid())
  tenantId      String
  callSid       String   @unique
  callerPhone   String?
  durationMs    Int      @default(0)
  bookingsMade  Int      @default(0)
  transcript    Json     @default("[]") // Array of { role, content }
  twilioStatus  String?  // "completed" | "failed" | "busy" | "no-answer"
  endedAt       DateTime?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("call_logs")
}

// ─── ACTIVITY LOG ──────────────────────────────────────────────────────────────
// Audit trail of things that happen in the clinic (bookings, calls, payments…).
model ActivityLog {
  id          String   @id @default(uuid())
  tenantId    String
  type        String   @db.VarChar(60)   // e.g. "appointment_created"
  description String   @db.Text          // HTML-safe string shown in the feed
  icon        String?  @db.VarChar(8)    // emoji
  bgColor     String?  @db.VarChar(20)   // hex background for icon
  entityType  String?  @db.VarChar(50)   // "appointment" | "client" | "call" …
  entityId    String?  @db.VarChar(36)
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// ─── ONBOARDING TOKENS ────────────────────────────────────────────────────────
model OnboardingToken {
  id        String    @id @default(uuid())
  token     String    @unique @db.VarChar(64)
  tenantId  String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("onboarding_tokens")
}

// ─── CONSULTATION RULES ───────────────────────────────────────────────────────
model ConsultationRule {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  durationMins  Int      @default(30)
  availableDays Json     @default("[1,2,3,4,5]")
  timeBlocks    Json     @default("[{\"start\":\"09:00\",\"end\":\"17:00\"}]")
  bufferMins    Int      @default(15)
  maxPerDay     Int      @default(10)
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("consultation_rules")
}

// ─── BLACKOUT DATES ───────────────────────────────────────────────────────────
model BlackoutDate {
  id       String   @id @default(uuid())
  tenantId String
  date     DateTime @db.Date
  label    String?  @db.VarChar(255)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("blackout_dates")
}

// ─── BOOKING ENGINE LOGS ──────────────────────────────────────────────────────
model BookingEngineLog {
  id               String   @id @default(uuid())
  tenantId         String
  appointmentId    String?
  source           String   @db.VarChar(50)
  outcome          String   @db.VarChar(20)
  validationErrors Json     @default("[]")
  createdAt        DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@map("booking_engine_logs")
}

// ─── BRAND VOICE ──────────────────────────────────────────────────────────────
model BrandVoice {
  id           String   @id @default(uuid())
  tenantId     String   @unique
  tone         String   @default("luxury")
  wordsToAvoid Json     @default("[]")
  specialNotes String?  @db.Text
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("brand_voices")
}
