# ─────────────────────────────────────────────────────────────────────────────
# MediBook Backend Environment Variables
# Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────────────────────

# Server Configuration
PORT=3001
NODE_ENV=development
PUBLIC_URL=https://your-ngrok-url.ngrok.io
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/medibook

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# ElevenLabs Text-to-Speech (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_MODEL=eleven_turbo_v2

# Deepgram Speech-to-Text (https://console.deepgram.com)
DEEPGRAM_API_KEY=your-deepgram-key
DEEPGRAM_MODEL=nova-2-medical

# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe (https://dashboard.stripe.com/apikeys)
# Use test keys for development: sk_test_..., pk_test_...
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create in Stripe Dashboard → Products)
# Start plan — £199/month or £1,990/year (2 months free)
STRIPE_PRICE_START_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_START_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxx
# PR plan — £399/month or £3,990/year (2 months free)
STRIPE_PRICE_PR_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PR_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxx
# Enterprise plan — custom pricing (contact sales)
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Email (optional, for notifications)
# RESEND_API_KEY=re_your-resend-key
# EMAIL_FROM=notifications@yourdomain.com
# EMAIL_REPLY_TO=support@yourdomain.com

# Logging
LOG_LEVEL=info
